<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Environ.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Environ"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" MaxWidth="600"
                    HorizontalAlignment="Left">

            <!-- App identity -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <FontIcon Glyph="&#xE770;" FontSize="48"/>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Environ"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="A modern Windows environment variable editor"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>
            </StackPanel>

            <!-- Version -->
            <TextBlock Text="Version 1.0"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.5"/>

            <!-- Links -->
            <StackPanel Spacing="8">
                <TextBlock Text="Links" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <HyperlinkButton Content="GitHub Repository"
                                 NavigateUri="https://github.com/gersonkurz/environ"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
