<Window
    x:Class="EnvironNativeBaseline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EnvironNativeBaseline"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Environ Native Baseline">

    <Grid>
        <Grid.Resources>
            <Style x:Key="FlatListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="16,12,16,12" Spacing="4">
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Text="Environ Native Baseline" />
            <TextBlock x:Name="SummaryText"
                       Opacity="0.7"
                       Text="Loading environment variables..." />
            <StackPanel x:Name="DirtyStatePanel"
                        Orientation="Horizontal"
                        Spacing="12">
                <TextBlock x:Name="DirtyStateText"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           Opacity="0.9"
                           Text=""
                           VerticalAlignment="Center" />
                <Button x:Name="ApplyButton"
                        Click="OnApplyButtonClick"
                        Content="Apply"
                        IsEnabled="False"
                        Padding="10,4,10,4" />
                <Button x:Name="DiscardButton"
                        Click="OnDiscardButtonClick"
                        Content="Discard"
                        IsEnabled="False"
                        Padding="10,4,10,4" />
            </StackPanel>
        </StackPanel>

        <TextBox x:Name="FilterBox"
                 Grid.Row="1"
                 Margin="16,0,16,12"
                 PlaceholderText="Filter variables..."
                 TextChanged="OnFilterChanged" />

        <Grid Grid.Row="2"
              Margin="16,0,16,0"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.65"
                       Text="Name" />
            <TextBlock Grid.Column="1"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.65"
                       Text="Scope" />
            <TextBlock Grid.Column="2"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.65"
                       Text="Value" />
        </Grid>

        <ListView x:Name="ItemsList"
                  Grid.Row="3"
                  ItemContainerStyle="{StaticResource FlatListViewItemStyle}"
                  Margin="16,0,16,16"
                  IsItemClickEnabled="False"
                  SelectionChanged="OnItemsListSelectionChanged"
                  SelectionMode="Single" />
    </Grid>
</Window>
